---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a class="brand" href="/">
			<span class="brand-mark">01</span>
			<span class="brand-copy">
				<strong>{SITE_TITLE}</strong>
				<small>Matrix signal log</small>
			</span>
		</a>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
	</nav>
</header>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 20;
		padding: 0 1rem;
		backdrop-filter: blur(18px);
		background: linear-gradient(180deg, rgba(2, 8, 5, 0.9), rgba(2, 8, 5, 0.68));
		border-bottom: 1px solid var(--line);
	}

	nav {
		width: min(1180px, 100%);
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		min-height: 4.75rem;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.85rem;
		text-decoration: none;
		color: var(--text);
	}

	.brand-mark {
		display: grid;
		place-items: center;
		width: 2.6rem;
		height: 2.6rem;
		border: 1px solid var(--line-strong);
		border-radius: 999px;
		font-family: var(--mono);
		font-size: 0.8rem;
		letter-spacing: 0.12em;
		color: var(--accent);
		box-shadow: inset 0 0 18px rgba(123, 255, 159, 0.08);
		animation: brand-pulse 4s ease-in-out infinite;
	}

	@keyframes brand-pulse {
		0%, 100% {
			box-shadow: inset 0 0 18px rgba(123, 255, 159, 0.08);
		}
		50% {
			box-shadow:
				inset 0 0 18px rgba(123, 255, 159, 0.08),
				0 0 12px rgba(123, 255, 159, 0.2),
				0 0 24px rgba(123, 255, 159, 0.08);
		}
	}

	.brand-copy {
		display: grid;
		gap: 0.1rem;
	}

	.brand-copy strong {
		font-size: 0.96rem;
		letter-spacing: 0.04em;
		text-transform: uppercase;
	}

	.brand-copy small {
		font-family: var(--mono);
		font-size: 0.68rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--muted);
	}

	.internal-links {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: flex-end;
		gap: 1.1rem;
	}

	.internal-links :global(a) {
		padding: 0.45rem 0;
		font-family: var(--mono);
		font-size: 0.8rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--muted);
		border-bottom: 1px solid transparent;
	}

	.internal-links :global(a:hover),
	.internal-links :global(a.active) {
		color: var(--accent);
		border-bottom-color: var(--line-strong);
	}

	@media (max-width: 720px) {
		header {
			padding: 0 0.6rem;
		}

		nav {
			min-height: auto;
			flex-direction: column;
			align-items: stretch;
			justify-content: center;
			padding: 0.65rem 0;
			gap: 0.5rem;
		}

		.brand {
			width: 100%;
		}

		.internal-links {
			width: 100%;
			justify-content: space-between;
			gap: 0.2rem;
		}

		.internal-links :global(a) {
			flex: 1 1 0;
			justify-content: center;
			padding: 0.5rem 0.55rem;
			font-size: 0.75rem;
			min-height: 2.4rem;
			display: inline-flex;
			align-items: center;
		}
	}

	@media (max-width: 480px) {
		header {
			padding: 0 0.45rem;
		}

		nav {
			padding: 0.5rem 0 0.6rem;
		}

		.brand {
			gap: 0.6rem;
		}

		.brand-mark {
			width: 2.2rem;
			height: 2.2rem;
			font-size: 0.72rem;
		}

		.brand-copy strong {
			font-size: 0.85rem;
		}

		.brand-copy small {
			font-size: 0.62rem;
			letter-spacing: 0.14em;
		}

		.internal-links {
			display: grid;
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}

		.internal-links :global(a) {
			padding: 0.55rem 0.3rem;
			font-size: 0.68rem;
			letter-spacing: 0.12em;
		}
	}
</style>
